{
  "name": "memevault-desktop-suite",
  "version": "0.1.0",
  "description": "Local-first desktop vault for memes, screenshots, GIFs, and short clips.",
  "main": "out/main/index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.1",
    "chokidar": "^4.0.3",
    "ffmpeg-static": "^5.2.0",
    "lucide-react": "^0.468.0",
    "p-queue": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "tesseract.js": "^6.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.20",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.memevault.desktop",
    "productName": "MemeVault Desktop Suite",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/sharp/**/*",
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/ffmpeg-static/**/*"
    ]
  }
}
